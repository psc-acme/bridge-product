{
    "name": "psc-acme/bridge-product",
    "description": "Package bridge-product for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\BridgeProduct\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "guzzlehttp/psr7": "^2.0",
        "symfony/uid": "^7.0",
        "symfony/http-kernel": "^6.2",
        "webmozart/assert": "^1.0",
        "nikic/php-parser": "^5.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}